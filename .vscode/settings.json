{
  // 20260326-001 Chun-Standard V1.0 workspace baseline.
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "editor.formatOnSave": true,
  "task.allowAutomaticTasks": "on",

  "search.searchView.semanticSearchBehavior": "always",
  "workbench.settings.showAISearchToggle": true,

  "github.copilot.enable": {
    "*": true,
    "markdown": true,
    "plaintext": true,
    "scminput": true
  },
  "github.copilot.editor.enableCodeActions": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.nextEditSuggestions.fixes": true,
  "github.copilot.renameSuggestions.triggerAutomatically": true,
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "github.copilot.chat.organizationInstructions.enabled": true,
  "github.copilot.chat.organizationCustomAgents.enabled": true,
  "github.copilot.chat.commitMessageGeneration.instructions": [
    "Use concise Traditional Chinese or bilingual summaries when the repository already mixes English and Chinese.",
    "For workspace automation changes, prefer commit messages that include a YYYYMMDD-Tnn tag."
  ],
  "github.copilot.chat.pullRequestDescriptionGeneration.instructions": [
    "Summarize environment automation changes by 5-track sections and mention any platform-specific limitations."
  ],
  "github.copilot.chat.additionalReadAccessFolders": [
    "${workspaceFolder}/.relay/m365-current",
    "${workspaceFolder}/.relay/obsidian-current"
  ],
  "github.copilot.chat.editor.temporalContext.enabled": true,

  "chat.agent.enabled": true,
  "chat.agent.maxRequests": 50,
  "chat.autopilot.enabled": true,
  "chat.useAgentsMdFile": true,
  "chat.useAgentSkills": true,
  "chat.agentFilesLocations": {
    ".github/agents": true
  },
  "chat.instructionsFilesLocations": {
    ".github/instructions": true
  },
  "chat.includeApplyingInstructions": true,
  "chat.mcp.access": true,
  "chat.mcp.discovery.enabled": false,
  "chat.mcp.autoStart": "newAndOutdated",

  "editor.inlineSuggest.edits.allowCodeShifting": "always",
  "editor.inlineSuggest.showToolbar": "onHover",

  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,

  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html"
  ],
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "terminal.integrated.env.linux": {
    "CHUN_STANDARD_VERSION": "1.0",
    "CHUN_STANDARD_DATE_TAG": "20260326",
    "RELAY_ENV_FILE": "${workspaceFolder}/.env.relay",
    "M365_DIGEST_SOURCE": "${workspaceFolder}/ops/relay/m365-digest-pool",
    "OBSIDIAN_LOGIC_SOURCE": "${workspaceFolder}/ops/relay/obsidian-logic-vault"
  }
}
