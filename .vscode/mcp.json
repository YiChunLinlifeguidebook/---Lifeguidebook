{
  "servers": {
    "workspaceFiles": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${workspaceFolder}"
      ],
      "sandboxEnabled": true,
      "sandbox": {
        "filesystem": {
          "allowWrite": [
            "${workspaceFolder}"
          ],
          "denyRead": [
            "${userHome}/.ssh",
            "${userHome}/.gnupg"
          ]
        },
        "network": {
          "allowedDomains": [
            "registry.npmjs.org",
            "open-vsx.org",
            "api.github.com"
          ]
        }
      }
    }
  }
}
