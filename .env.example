# LINE Messaging API — 從 LINE Developers Console 取得後複製到此檔案的副本 `.env`
# 取得路徑：選擇 Provider → 你的 Messaging API Channel → Messaging API 分頁
#
# 請勿將填好真值的 `.env` 提交到 Git。

LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# 選填，預設 3000
# PORT=3000

# --- Google / Vertex（多腦架構，依 docs/google-meta-integration.md 填入）---
# GOOGLE_AI_API_KEY=
# GOOGLE_CLOUD_PROJECT=
# VERTEX_AI_LOCATION=us-central1

# --- Meta / Llama（若經 Vertex 或其他託管，依供應商文件設定）---
# META_LLAMA_ENDPOINT=

# --- 本機開發：放寬內建 Guard stub（非繞過雲端安全；production 請勿設為 1）---
# DEV_RELAXED_MODE=1

# --- 批次採集節流（毫秒，預設 800）---
# INGEST_DELAY_MS=800

# --- 假名化（外部 userId → 內部穩定編號，須高熵密鑰；勿提交）---
# PSEUDONYM_SECRET=
# 或別名：PII_SUBJECT_SALT=
